import numpy as np
import matplotlib.pyplot as plt

X = np.arange(1, 21)
Y = 2*X + 1
print("X", X)
print("Y", Y)

m, c = np.polyfit(X, Y, 1)

print("Slope (m):", round(m, 2))
print("Intercept (c):", round(c, 2))

Y_pred = m*X + c
print("Y_pred: ", Y_pred)

plt.scatter(X, Y)
plt.plot(X, Y_pred)
plt.show()
